# ── Banco de dados ──────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=inquilinotop
POSTGRES_PORT=5432

# ── Backend Go ───────────────────────────────────────────────
DATABASE_URL=postgres://postgres:postgres@localhost:5432/inquilinotop?sslmode=disable
TEST_DATABASE_URL=postgres://postgres:postgres@localhost:5433/inquilinotop_test?sslmode=disable
MIGRATIONS_PATH=./migrations
BACKEND_PORT=8080
PORT=8080
JWT_PRIVATE_KEY_PATH=./backend/keys/private.pem
JWT_PUBLIC_KEY_PATH=./backend/keys/public.pem
APP_ENV=development
LOG_LEVEL=info

# ── CORS ─────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Email / SMTP ─────────────────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM=noreply@inquilinotop.com

# ── Pagamentos ──────────────────────────────────────────────
PAYMENT_PROVIDER=mock

# ── Documentos ──────────────────────────────────────────────
DOCUMENT_STORAGE_PATH=./storage/documents

# ── Frontend Next.js ─────────────────────────────────────────
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_SUPABASE_URL=https://<project>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>

# ── Sentry ───────────────────────────────────────────────────
# Projetos em https://sentry.io (org: mayco-aoki-consult)
BACKEND_SENTRY_DSN=https://d79500ec6943f0d793aa3305ff8c6bda@o4509690008698880.ingest.us.sentry.io/4511333100093440
NEXT_PUBLIC_SENTRY_DSN=https://<key>@o4509690008698880.ingest.us.sentry.io/<frontend-project-id>
# Usado pelo withSentryConfig para upload de source maps em build
SENTRY_ORG=mayco-aoki-consult
SENTRY_PROJECT=javascript-nextjs
SENTRY_AUTH_TOKEN=<auth-token-do-sentry>
APP_VERSION=1.0.0
